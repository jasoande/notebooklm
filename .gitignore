# Project APE - Git Ignore File

# ==============================================================================
# CRITICAL: Prevent Customer Data Leaks
# ==============================================================================

# Never commit actual client configuration (contains customer names, paths)
vars.py

# Never commit authentication files
.shared_auth.json
.storage_*.json
*.context.json

# ==============================================================================
# Generated Files
# ==============================================================================

# Dashboard and logs
project_ape_dashboard.html
*.log

# State files
pipeline_state.json
pipeline_metrics.json

# Temporary files
.temp_*
*.tmp
*.pyc
__pycache__/

# Virtual environment
venv/
env/
.venv/

