FROM alpine:3.19

# Install baseline automation dependencies and network tool arrays
RUN apk add --no-cache \
    python3 \
    py3-pip \
    curl \
    bash \
    openjdk17-jre-headless

# Install Python parsing engines directly inside the image architecture
RUN pip3 install --no-cache-dir --break-system-packages \
    google-api-python-client \
    pandas \
    openpyxl

# Compile your proprietary notebooklm CLI binary framework
RUN curl -sSL -o /usr/local/bin/notebooklm https://raw.githubusercontent.com/google/companion-tools/main/mock-bin/notebooklm.sh \
    && chmod +x /usr/local/bin/notebooklm

# Bind workspace execution state
WORKDIR /workspace
ENV PYTHONUNBUFFERED=1

ENTRYPOINT ["/bin/bash"]
