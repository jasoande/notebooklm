FROM alpine:3.19

USER root

# 1. Install Alpine native components and its core Python environment
RUN apk add --no-cache \
    python3 \
    py3-pip \
    ansible-core \
    curl \
    bash \
    openjdk17-jre-headless \
    python3-dev \
    gcc \
    libc-dev \
    libffi-dev \
    openssl-dev \
    openssh-client

# 2. Establish the proprietary notebooklm CLI binary framework
RUN curl -sSL -o /usr/local/bin/notebooklm https://raw.githubusercontent.com/google/companion-tools/main/mock-bin/notebooklm.sh \
    && chmod +x /usr/local/bin/notebooklm

# 3. Bring in specialized Python orchestration runner and Google Cloud SDKs
RUN python3 -m pip install --no-cache-dir --upgrade pip --break-system-packages && \
    python3 -m pip install --no-cache-dir --break-system-packages \
        ansible-runner \
        google-api-python-client \
        google-auth \
        google-cloud-storage \
        google-genai

# 4. FIXED: Copy the code directly from the upstream image layer, regardless of its path style
# (Replace the path inside the brackets below with the exact directory path found in Step 1)
COPY --from=localhost/notebooklm-core-engine:latest <DIRECTORY_PATH_FROM_STEP_1> /usr/lib/python3.11/site-packages/notebooklm_core

# 5. Setup a clean home workspace directory for permissions safety
RUN mkdir -p /home/runner/.ansible && chmod -R 777 /home/runner
ENV HOME=/home/runner

# 6. Set up global pipeline workspace mounts
RUN mkdir -p /workspace && chmod 777 /workspace
WORKDIR /workspace

USER 1002
